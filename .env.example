SECRET_KEY=replace-this-with-a-long-random-secret
DATABASE_URL=postgresql+psycopg2://rbac:rbacpass@localhost:5432/rbac_chatbot
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai
LLM_TIMEOUT_S=30
EMBED_PROVIDER=openai
EMBED_TIMEOUT_S=30

# Set these when the vector store runs as a separate Chroma container.
# CHROMA_HOST=chroma
# CHROMA_PORT=8000
# CHROMA_SSL=false

# Raw document files are copied to this filesystem path; PostgreSQL stores only references.
DOCUMENT_STORE_PATH=resources/document_store

# Leave this for local fallback mode when Chroma is embedded in the process.
VECTOR_DB_PATH=resources/vectorstore/chroma
VECTOR_COLLECTION=rbac_docs
AUDIT_LOG_PATH=resources/audit/audit.log
REQUEST_BODY_MAX_BYTES=20000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
INGEST_MAX_ATTEMPTS=3
INGEST_RETRY_BACKOFF_SECONDS=2
